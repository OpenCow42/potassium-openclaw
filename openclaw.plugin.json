{
  "id": "infomaniak",
  "name": "Infomaniak",
  "description": "Use the prebuilt Potassium CLI command pot to interact with Infomaniak APIs.",
  "activation": {
    "onStartup": true
  },
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "potPath": {
        "type": "string",
        "description": "Absolute path to the Potassium pot binary. Defaults to PATH lookup."
      },
      "tokenEnvName": {
        "type": "string",
        "description": "Environment variable containing the Infomaniak bearer token."
      },
      "defaultFormat": {
        "anyOf": [
          {
            "type": "string",
            "const": "json"
          },
          {
            "type": "string",
            "const": "text"
          }
        ]
      },
      "mutationMode": {
        "anyOf": [
          {
            "type": "string",
            "const": "deny"
          },
          {
            "type": "string",
            "const": "allow"
          }
        ]
      },
      "outputRoot": {
        "type": "string",
        "description": "Containment root for --output paths."
      },
      "timeoutMs": {
        "type": "number",
        "minimum": 1000
      },
      "maxOutputBytes": {
        "type": "number",
        "minimum": 1024
      }
    }
  },
  "version": "0.1.0",
  "contracts": {
    "tools": [
      "infomaniak_search_commands",
      "infomaniak_read",
      "infomaniak_mutate"
    ]
  },
  "toolMetadata": {
    "infomaniak_mutate": {
      "optional": true
    }
  }
}
