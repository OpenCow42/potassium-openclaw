{
  "id": "infomaniak",
  "name": "Infomaniak",
  "description": "Use the prebuilt Potassium CLI (`pot`) to interact with Infomaniak APIs.",
  "contracts": {
    "tools": [
      "infomaniak_search_commands",
      "infomaniak_read",
      "infomaniak_mutate"
    ]
  },
  "toolMetadata": {
    "infomaniak_mutate": {
      "optional": true
    }
  },
  "activation": {
    "onStartup": true
  },
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "potPath": {
        "type": "string",
        "description": "Absolute path to the prebuilt Potassium CLI binary (`pot`). Defaults to PATH lookup."
      },
      "tokenEnvName": {
        "type": "string",
        "description": "Environment variable that contains the Infomaniak bearer token."
      },
      "defaultFormat": {
        "type": "string",
        "enum": [
          "json",
          "text"
        ]
      },
      "mutationMode": {
        "type": "string",
        "enum": [
          "deny",
          "allow"
        ]
      },
      "outputRoot": {
        "type": "string",
        "description": "Required containment directory for commands that write to --output."
      },
      "timeoutMs": {
        "type": "number",
        "minimum": 1000
      },
      "maxOutputBytes": {
        "type": "number",
        "minimum": 1024
      }
    }
  }
}
