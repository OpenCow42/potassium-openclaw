{
  "name": "@opencow42/potassium-openclaw",
  "version": "0.4.0",
  "type": "module",
  "description": "Native OpenClaw tools and skills for Infomaniak kDrive, Mail, kChat, URL shortener, and discovery workflows.",
  "license": "Apache-2.0",
  "author": "OpenCow",
  "homepage": "https://opencow42.github.io/potassium-openclaw/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenCow42/potassium-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/OpenCow42/potassium-openclaw/issues"
  },
  "keywords": [
    "codex-plugin",
    "infomaniak",
    "kchat",
    "kdrive",
    "openclaw",
    "potassium",
    "skills"
  ],
  "main": "./index.js",
  "exports": {
    ".": "./index.js"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.6",
      "minGatewayVersion": "2026.6.6"
    },
    "build": {
      "openclawVersion": "2026.6.6",
      "pluginSdkVersion": "2026.6.6"
    },
    "install": {
      "clawhubSpec": "@opencow42/potassium-openclaw",
      "npmSpec": "@opencow42/potassium-openclaw",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.6"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".codex-plugin",
    "openclaw.plugin.json",
    "index.js",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "docs",
    "skills"
  ],
  "scripts": {
    "check": "node --check index.js && node --check test/skill-metadata.test.js && node --check test/skills-first-package.test.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "liquid-potassium": "0.3.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.6"
  },
  "devDependencies": {
    "openclaw": "^2026.6.6"
  },
  "engines": {
    "node": ">=22"
  }
}
