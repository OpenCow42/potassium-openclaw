{
  "name": "@opencow/potassium-openclaw",
  "version": "0.2.0",
  "type": "module",
  "description": "OpenClaw Infomaniak tools and skills backed by the liquid-potassium Node SDK.",
  "license": "Apache-2.0",
  "author": "OpenCow",
  "homepage": "https://github.com/OpenCow42/potassium-openclaw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenCow42/potassium-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/OpenCow42/potassium-openclaw/issues"
  },
  "keywords": [
    "codex-plugin",
    "infomaniak",
    "kchat",
    "kdrive",
    "openclaw",
    "potassium",
    "skills"
  ],
  "main": "./index.js",
  "exports": {
    ".": "./index.js"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".codex-plugin",
    "openclaw.plugin.json",
    "index.js",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "docs",
    "skills"
  ],
  "scripts": {
    "check": "node --check index.js && node --check test/skill-metadata.test.js && node --check test/skills-first-package.test.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "liquid-potassium": "0.2.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.6"
  },
  "devDependencies": {
    "openclaw": "^2026.6.6"
  },
  "engines": {
    "node": ">=22"
  }
}
